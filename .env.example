# ============================================================
# WORLD CUP PREDICTOR — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # Server only — never expose client-side

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="World Cup Predictor 2026"

# ─── Active competition ───────────────────────────────────────
NEXT_PUBLIC_COMPETITION_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# ─── Live data sync (rutas /api/sync/*) ─────────────────────
# API-Football (api-sports.io) — resultados / marcadores en vivo
SPORTS_API_KEY=your-api-football-key
SPORTS_API_HOST=v3.football.api-sports.io
SPORTS_API_LEAGUE=1          # 1 = FIFA World Cup
SPORTS_API_SEASON=2026

# The Odds API (the-odds-api.com) — cuotas -> value bets
ODDS_API_KEY=your-odds-api-key
ODDS_API_SPORT=soccer_fifa_world_cup

# Secreto para proteger las rutas /api/sync/* (Vercel Cron lo envia como
# `Authorization: Bearer <CRON_SECRET>`). Genera uno aleatorio largo.
CRON_SECRET=genera-un-secreto-aleatorio-largo

# Peso del mercado al calibrar predicciones (0..1). Def 0.6 = 60% mercado.
RECALIBRATE_ALPHA=0.6
